FROM rustlang/rust:nightly AS chef
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends lld clang curl && rm -rf /var/lib/apt/lists/*
RUN rustup show active-toolchain | awk '{print $1}' > /rust_toolchain
RUN TOOLCHAIN=$(cat /rust_toolchain) && \
    rustup component add --toolchain "$TOOLCHAIN" rustfmt clippy miri
RUN cargo install --locked cargo-chef

FROM chef AS planner
COPY . .
RUN RUSTUP_TOOLCHAIN=$(cat /rust_toolchain) cargo chef prepare --recipe-path recipe.json

FROM chef AS dev
RUN cargo install --locked cargo-watch
# Pre-cook dependencies — this layer is cached until Cargo.lock changes
COPY --from=planner /app/recipe.json recipe.json
RUN RUSTUP_TOOLCHAIN=$(cat /rust_toolchain) cargo chef cook --recipe-path recipe.json
# Source is mounted at runtime via Docker Compose Watch
COPY . .
CMD ["./scripts/dev-boot.sh"]
