#!/usr/bin/env bash
set -euo pipefail

# Only run in interactive shells
if [[ ! -t 1 ]]; then
  exit 0
fi

########################################
# CONFIG
########################################
TEMPLATE_FILE=".rust_template_version"
TEMPLATE_REMOTE="https://github.com/MrCartaaa/rust_template.git"
TEMPLATE_SSH="git@github.com:MrCartaaa/rust_template.git"
TEMPLATE_BRANCH="main"

# Detect repo remote URL
CURRENT_REMOTE_URL=$(git remote get-url origin 2>/dev/null || true)

IS_TEMPLATE_REPO=false
if [[ "$CURRENT_REMOTE_URL" == "$TEMPLATE_REMOTE" ]] || [[ "$CURRENT_REMOTE_URL" == "$TEMPLATE_SSH" ]]; then
  IS_TEMPLATE_REPO=true
fi

# --- Ensure version file exists ---
if [[ ! -f "$TEMPLATE_FILE" ]]; then
  echo "❌ ERROR: $TEMPLATE_FILE not found."
  echo "This project must declare which template commit it is based on."
  exit 1
fi

CURRENT_SHA=$(tr -d ' \r\n' <"$TEMPLATE_FILE")

########################################
# TEMPLATE REPO LOGIC
########################################
if [[ "$IS_TEMPLATE_REPO" == true ]]; then
  # Get previous commit's version file content (if exists)
  if git show HEAD:"$TEMPLATE_FILE" >/dev/null 2>&1; then
    PREV_SHA=$(git show HEAD:"$TEMPLATE_FILE" | tr -d ' \r\n')
  else
    PREV_SHA=""
  fi

  # If same → bump version marker
  if [[ "$CURRENT_SHA" == "$PREV_SHA" ]]; then
    echo "📝 Bumping template version marker…"

    # Generate a new random SHA/UUID (portable)
    NEW_SHA=$(uuidgen 2>/dev/null || cat /proc/sys/kernel/random/uuid 2>/dev/null || openssl rand -hex 16)

    echo "$NEW_SHA" >"$TEMPLATE_FILE"
    git add "$TEMPLATE_FILE"

    echo
    echo "⚠️ Template version updated to: $NEW_SHA"
    echo "Please commit again."
    exit 1
  fi

  echo "✔ Template version changed — commit allowed"
  exit 0
fi

########################################
# CLIENT REPO LOGIC
########################################
# Fetch latest SHA of template main branch
REMOTE_SHA=$(git ls-remote "$TEMPLATE_REMOTE" "refs/heads/$TEMPLATE_BRANCH" | awk '{print $1}')

if [[ -z "$REMOTE_SHA" ]]; then
  echo "❌ ERROR: Could not read remote SHA from:"
  echo "   $TEMPLATE_REMOTE ($TEMPLATE_BRANCH)"
  exit 1
fi

# Compare
if [[ "$CURRENT_SHA" != "$REMOTE_SHA" ]]; then
  echo "❌ Template out of date — commit blocked"
  echo
  echo "Latest template commit : $REMOTE_SHA"
  echo "Your project expects   : $CURRENT_SHA"
  echo
  echo "Update from template by running sync_rust_template.sh, see DEVELOPMENT.md for details."
  exit 1
fi

echo "✔ Template version OK ($CURRENT_SHA)"
exit 0
